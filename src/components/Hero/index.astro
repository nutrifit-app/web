---

<section class="hero-section w-full min-h-screen flex flex-col xl:flex-row justify-center items-center p-8 relative">
	<canvas id="network-canvas" class="absolute inset-0 w-full h-full"></canvas>
	<div class="flex items-center justify-center w-1/2 relative z-10">
		<img
			src={import.meta.env.PUBLIC_PATH_URL + "/nutrifit-volume-logo.png"}
			alt="Nutrifit Volume Logo"
			class="hidden xl:block logo h-auto cursor-pointer xl:transition-all xl:duration-300 xl:ease-in-out xl:hover:scale-105"
		/>
		<img
			src={import.meta.env.PUBLIC_PATH_URL + "/nutrifit-logo.png"}
			alt="Nutrifit Volume Logo"
			class="block xl:hidden mobile-logo h-auto cursor-pointer xl:transition-all xl:duration-300 xl:ease-in-out xl:hover:scale-105"
		/>
	</div>
	<div class="flex flex-col gap-8 w-full xl:w-1/2 relative z-10">
		<p class="text-5xl lg:text-7xl justify-center font-bold bg-gradient-to-r from-[rgb(84,118,243)] to-[#9bbddd] bg-clip-text text-transparent flex flex-col gap-y-4 xl:max-w-[600px]">
			<span class="text-center xl:text-end">Tu mejor versión</span>
			<span class="text-center xl:text-end">empieza aquí.</span>
			<a
				href="https://wa.me/526862339446"
				target="_blank"
				rel="noopener noreferrer"
				class="cta-button self-center xl:self-end px-8 py-4 text-lg font-semibold text-white bg-[#5476f3] rounded-full transition-all duration-300 hover:scale-105 hover:shadow-2xl"
			>
				Agendar cita
			</a>
		</p>
	</div>
</section>

<script>
	import { initNetwork } from './network';

	const canvas = document.getElementById('network-canvas') as HTMLCanvasElement;
	// if (canvas) {
	// 	initNetwork(canvas);
	// }
</script>

<style>
	.hero-section {
		background:
			linear-gradient(to bottom right, rgba(11, 11, 64, 1), rgba(19, 24, 42, 0.85)),
			url('/nutrifit-desk.jpeg');
		background-position: center 25%;
		background-repeat: no-repeat;
		background-size: cover;
	}

	@media (width >= 1024px) {
		.hero-section {
			background-position: center;
		}
	}

	.logo {
		width: calc(50vw - 2rem);
		max-width: 600px;
		min-width: 250px;
		/* filter: drop-shadow(0 0 2px rgba(255, 255, 255, 0.9))
		        drop-shadow(0 0 8px rgba(0, 0, 0, 0.9))
		        drop-shadow(0 0 15px rgba(0, 0, 0, 0.8))
		        drop-shadow(0 0 25px rgba(0, 0, 0, 0.7))
		        drop-shadow(0 20px 40px rgba(0, 0, 0, 0.6)); */
		animation: float 2s ease-in-out infinite;
		transition: filter 0.3s ease-in-out, transform 0.3s ease-in-out, scale 0.3s ease-in-out;
	}

	.logo:hover {
		filter: drop-shadow(0 0 20px rgba(155, 189, 221, 0.8))
		        drop-shadow(0 0 40px rgba(155, 189, 221, 0.6))
		        drop-shadow(0 0 60px rgba(155, 189, 221, 0.4))
		        drop-shadow(0 0 80px rgba(155, 189, 221, 0.3))
		        drop-shadow(0 20px 40px rgba(0, 0, 0, 0.6));
	}

	@keyframes float {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(-25px);
		}
	}
</style>
