<style>
  .story-section {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .story-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .image-placeholder {
    position: sticky;
    top: 2rem;
    width: 100%;
    height: 500px;
    background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
    border-radius: 12px;
    border: 2px dashed #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: #999;
    text-align: center;
  }

  .placeholder-text {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .placeholder-hint {
    font-size: 0.875rem;
    font-style: italic;
  }

  .story-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .story-content h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 1rem;
  }

  .story-content p {
    font-size: 1rem;
    line-height: 1.8;
    color: #555;
    text-align: justify;
  }

  @media (max-width: 768px) {
    .story-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .image-placeholder {
      position: relative;
      top: 0;
      height: 300px;
    }

    .story-content h2 {
      font-size: 2rem;
    }
  }
</style>
