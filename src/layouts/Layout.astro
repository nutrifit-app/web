---
import { ViewTransitions } from "astro:transitions";
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Nutrióloga Andrea Guerrero, 
			consulta presencial y en línea. Mexicali, BC. 
			Plan alimenticio, nutrición deportiva, 
			nutrición en enfermedades, aumento de masa muscular,
			perdida de porcentaje de grasa.
			Planes de entrenamiento personalizados"
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="Nutrióloga Andrea Guerrero" content={Astro.generator} />
		<title >{title}</title>
		<ViewTransitions />
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(0deg, rgba(250,250,250,1) 0%, rgba(0,20,135,1) 0%, rgba(0,51,237,1) 100%);
		--text: #1A1A1A;
		--primary: #10A9EB;
		--secondary: #FF9800;
		--white: #F5F5F5;
	}
	html {
		font-family: 'Lexend Variable', sans-serif;
		background-color: var(--white);
		color: var(--text);
	}
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}

	body {
		margin: 0;
		width: 100%;
	}

	.action-button {
		background-color: var(--primary);
		color: var(--white);
		height: 2.5rem;
		border: none;
		border-radius: 8px;
		font-size: 1rem;
		font-weight: 800;
	}
</style>
